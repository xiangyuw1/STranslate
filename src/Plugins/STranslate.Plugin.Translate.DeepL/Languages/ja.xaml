<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <sys:String x:Key="STranslate_Plugin_Translate_DeepL_ApiKey">ApiKey</sys:String>
    <sys:String x:Key="STranslate_Plugin_Translate_DeepL_ApiKey_Placeholder">ApiKeyを入力してください</sys:String>
    <sys:String x:Key="STranslate_Plugin_Translate_DeepL_ApiKey_Description">DeepLキーを入力してください</sys:String>
    <sys:String x:Key="STranslate_Plugin_Translate_DeepL_ApiType">APIエンドポイント</sys:String>
    <sys:String x:Key="STranslate_Plugin_Translate_DeepL_ApiType_Description">DeepL APIのベースURLを選択するか、互換性のあるカスタムURLを入力します</sys:String>
    <sys:String x:Key="STranslate_Plugin_Translate_DeepL_CustomApiUrl_Placeholder">APIのベースURLを入力してください（例：https://api-us.deepl.com）</sys:String>
    <sys:String x:Key="STranslate_Plugin_Translate_DeepL_InvalidApiUrl">クエリパラメーターやフラグメントを含まない有効なHTTP(S) APIベースURLを入力してください</sys:String>
    <sys:String x:Key="STranslate_Plugin_Translate_DeepL_Usage">使用状況</sys:String>
    <sys:String x:Key="STranslate_Plugin_Translate_DeepL_Query">クエリ</sys:String>
    <sys:String x:Key="STranslate_Plugin_Translate_DeepL_Query_Success">クエリ成功</sys:String>
    <sys:String x:Key="STranslate_Plugin_Translate_DeepL_Query_Fail">クエリ失敗</sys:String>
    <sys:String x:Key="STranslate_Plugin_Translate_DeepL_Query_Cancel">クエリをキャンセル</sys:String>
    <sys:String x:Key="STranslate_Plugin_Translate_DeepL_Query_Error1">使用状況が空です</sys:String>
    <sys:String x:Key="STranslate_Plugin_Translate_DeepL_Query_Error2">使用制限が空です</sys:String>

</ResourceDictionary>
