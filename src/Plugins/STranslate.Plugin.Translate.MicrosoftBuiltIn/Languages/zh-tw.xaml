<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <sys:String x:Key="STranslate_Plugin_Translate_Microsoft">介紹</sys:String>
    <sys:String x:Key="STranslate_Plugin_Translate_Microsoft_Content">本插件可免費使用微軟翻譯服務。</sys:String>
    <sys:String x:Key="STranslate_Plugin_Translate_Microsoft_RequestMode">請求方案</sys:String>
    <sys:String x:Key="STranslate_Plugin_Translate_Microsoft_RequestMode_Description">Default 為相容舊簽章方案，EdgeToken 為新授權方案；若目前方案請求失敗，可切換到另一方案重試。</sys:String>
    <sys:String x:Key="STranslate_Plugin_Translate_Microsoft_RequestMode_Legacy">Default</sys:String>
    <sys:String x:Key="STranslate_Plugin_Translate_Microsoft_RequestMode_Edge">EdgeToken</sys:String>

