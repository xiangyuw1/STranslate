<ui:ContentDialog
    x:Class="STranslate.Controls.UpdateChangelogDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cnvt="clr-namespace:STranslate.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
    xmlns:markdig="clr-namespace:Markdig.Wpf;assembly=Markdig.Wpf"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sys="clr-namespace:System;assembly=System.Runtime"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    Title="{DynamicResource UpdateAvailable}"
    d:DesignHeight="650"
    d:DesignWidth="900"
    CloseButtonText="{DynamicResource Cancel}"
    DefaultButton="Primary"
    PrimaryButtonStyle="{DynamicResource {x:Static ui:ThemeKeys.AccentButtonStyleKey}}"
    PrimaryButtonText="{DynamicResource PluginMarketDownload}"
    mc:Ignorable="d">

    <FrameworkElement.CommandBindings>
        <CommandBinding Command="{x:Static markdig:Commands.Hyperlink}" Executed="OpenHyperlink" />
    </FrameworkElement.CommandBindings>

    <ui:ContentDialog.Resources>
        <sys:Double x:Key="ContentDialogMaxWidth">880</sys:Double>
        <sys:Double x:Key="ContentDialogMaxHeight">620</sys:Double>
        <sys:Double x:Key="ContentDialogMinWidth">640</sys:Double>
        <sys:Double x:Key="ContentDialogMinHeight">420</sys:Double>
    </ui:ContentDialog.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            Margin="0,0,0,10"
            FontWeight="SemiBold"
            Text="{Binding HeaderText}" />

        <Grid Grid.Row="1">
            <Border
                Padding="0,20"
                Visibility="{Binding IsLoading, Converter={cnvt:BoolToVisibilityConverter}}">
                <ikw:SimpleStackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="12">
                    <ui:ProgressRing
                        Width="42"
                        Height="42"
                        IsActive="{Binding IsLoading}" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        Foreground="{DynamicResource {x:Static ui:ThemeKeys.TextFillColorSecondaryBrushKey}}"
                        Text="{DynamicResource UpdateChangelogLoading}" />
                </ikw:SimpleStackPanel>
            </Border>

            <ui:ScrollViewerEx
                x:Name="PART_ContentScrollViewer"
                Background="Transparent"
                VerticalScrollBarVisibility="Auto"
                Visibility="{Binding IsLoading, Converter={cnvt:BoolToVisibilityInverseConverter}}">
                <markdig:MarkdownViewer
                    Background="Transparent"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    Markdown="{Binding MarkdownContent}"
                    PreviewMouseWheel="MarkdownViewerPreviewMouseWheel" />
            </ui:ScrollViewerEx>
        </Grid>
    </Grid>
</ui:ContentDialog>
