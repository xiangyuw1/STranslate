<UserControl
    x:Class="STranslate.Controls.NoticeBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:plugin="clr-namespace:STranslate.Plugin;assembly=STranslate.Plugin"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    x:Name="Root"
    Background="{x:Null}"
    Focusable="False">
    <UserControl.Resources>
        <!--  图标：Unicode 符号 → Fluent System Icons，与项目其它控件统一  -->
        <Style x:Key="NoticeIconStyle" TargetType="ui:FontIcon">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Margin" Value="0,0,12,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource SystemControlBackgroundAccentBrush}" />
            <Setter Property="Icon" Value="{x:Static ui:FluentSystemIcons.Info_24_Regular}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Severity, ElementName=Root}" Value="{x:Static plugin:Severity.Success}">
                    <Setter Property="Icon" Value="{x:Static ui:FluentSystemIcons.CheckmarkCircle_24_Regular}" />
                    <Setter Property="Foreground" Value="{DynamicResource SystemFillColorSuccessBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Severity, ElementName=Root}" Value="{x:Static plugin:Severity.Warning}">
                    <Setter Property="Icon" Value="{x:Static ui:FluentSystemIcons.Warning_24_Regular}" />
                    <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCautionBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Severity, ElementName=Root}" Value="{x:Static plugin:Severity.Error}">
                    <Setter Property="Icon" Value="{x:Static ui:FluentSystemIcons.DismissCircle_24_Regular}" />
                    <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCriticalBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NoticeTitleStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,2" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Style.Triggers>
                <Trigger Property="Text" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>
                <Trigger Property="Text" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NoticeMessageStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Style.Triggers>
                <Trigger Property="Text" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>
                <Trigger Property="Text" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--  动作按钮：套用主题 Accent 样式，空内容时折叠  -->
        <Style x:Key="NoticeActionButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Margin" Value="16,0,0,0" />
            <Setter Property="Padding" Value="14,5" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="ui:ControlHelper.CornerRadius" Value="6" />
            <Setter Property="Foreground" Value="{DynamicResource TextOnAccentFillColorPrimaryBrush}" />
            <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <Trigger Property="Content" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>
                <Trigger Property="Content" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentFillColorSecondaryBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorSecondaryBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentFillColorTertiaryBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorTertiaryBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--  关闭按钮：圆形热区 + hover 反馈，对齐 Win11 InfoBar  -->
        <Style x:Key="NoticeCloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="ToolTip" Value="{DynamicResource Close}" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="HoverRoot"
                            Background="Transparent"
                            CornerRadius="16">
                            <ui:FontIcon
                                FontSize="12"
                                Foreground="{TemplateBinding Foreground}"
                                Icon="{x:Static ui:FluentSystemIcons.Dismiss_24_Regular}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HoverRoot" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="HoverRoot" Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsClosable, ElementName=Root}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border
        Padding="16,12"
        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
        BorderThickness="1"
        CornerRadius="8">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!--  左侧 severity 色条：圆角左侧，强化等级识别  -->
            <Border
                Grid.Column="0"
                Width="4"
                Height="20"
                Margin="0,0,14,0"
                VerticalAlignment="Center"
                CornerRadius="2">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAccentBrush}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Severity, ElementName=Root}" Value="{x:Static plugin:Severity.Success}">
                                <Setter Property="Background" Value="{DynamicResource SystemFillColorSuccessBrush}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Severity, ElementName=Root}" Value="{x:Static plugin:Severity.Warning}">
                                <Setter Property="Background" Value="{DynamicResource SystemFillColorCautionBrush}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Severity, ElementName=Root}" Value="{x:Static plugin:Severity.Error}">
                                <Setter Property="Background" Value="{DynamicResource SystemFillColorCriticalBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
            </Border>

            <ui:FontIcon Grid.Column="1" Style="{StaticResource NoticeIconStyle}" />

            <StackPanel
                Grid.Column="2"
                VerticalAlignment="Center"
                Orientation="Vertical">
                <TextBlock Style="{StaticResource NoticeTitleStyle}" Text="{Binding Title, ElementName=Root}" />
                <TextBlock
                    Style="{StaticResource NoticeMessageStyle}"
                    Text="{Binding Message, ElementName=Root}" />
            </StackPanel>

            <Button
                Grid.Column="3"
                Click="OnActionButtonClick"
                Content="{Binding ActionText, ElementName=Root}"
                Style="{StaticResource NoticeActionButtonStyle}" />

            <Button
                Grid.Column="4"
                AutomationProperties.Name="{DynamicResource Close}"
                Click="OnCloseButtonClick"
                Style="{StaticResource NoticeCloseButtonStyle}" />
        </Grid>
    </Border>
</UserControl>
