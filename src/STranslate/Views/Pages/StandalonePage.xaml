<ui:Page
    x:Class="STranslate.Views.Pages.StandalonePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cnvt="clr-namespace:STranslate.Converters"
    xmlns:control="clr-namespace:STranslate.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    xmlns:vm="clr-namespace:STranslate.ViewModels.Pages"
    Title="Standalone"
    d:DataContext="{d:DesignInstance Type=vm:StandaloneViewModel,
                                     IsDesignTimeCreatable=False}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <DockPanel Margin="20,10,20,12">
            <TextBlock Style="{DynamicResource {x:Static ui:ThemeKeys.SubtitleTextBlockStyleKey}}" Text="{DynamicResource Standalone}" />

            <ui:AutoSuggestBox
                x:Name="PART_AutoSuggestBox"
                MinWidth="200"
                MaxWidth="500"
                HorizontalAlignment="Right"
                DockPanel.Dock="Right"
                PlaceholderText="{DynamicResource SearchFunction}"
                ToolTip="{DynamicResource SearchFunctionToolTip}"
                ToolTipService.InitialShowDelay="200"
                ToolTipService.Placement="Top">
                <i:Interaction.Triggers>
                    <i:EventTrigger EventName="TextChanged">
                        <i:InvokeCommandAction
                            Command="{Binding TextChangedCommand}"
                            EventArgsConverter="{cnvt:EventArgsConverter}"
                            EventArgsConverterParameter="{Binding ElementName=PART_AutoSuggestBox}"
                            PassEventArgsToCommand="True" />
                    </i:EventTrigger>
                    <i:EventTrigger EventName="SuggestionChosen">
                        <i:InvokeCommandAction
                            Command="{Binding SuggestionChosenCommand}"
                            EventArgsConverter="{cnvt:EventArgsConverter}"
                            EventArgsConverterParameter="{Binding ElementName=PART_AutoSuggestBox}"
                            PassEventArgsToCommand="True" />
                    </i:EventTrigger>
                    <i:EventTrigger EventName="QuerySubmitted">
                        <i:InvokeCommandAction
                            Command="{Binding QuerySubmittedCommand}"
                            EventArgsConverter="{cnvt:EventArgsConverter}"
                            EventArgsConverterParameter="{Binding ElementName=PART_ScrollViewer}"
                            PassEventArgsToCommand="True" />
                    </i:EventTrigger>
                </i:Interaction.Triggers>
                <ui:AutoSuggestBox.QueryIcon>
                    <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.Search_20_Regular}" />
                </ui:AutoSuggestBox.QueryIcon>
            </ui:AutoSuggestBox>
        </DockPanel>

        <ui:ScrollViewerEx x:Name="PART_ScrollViewer" Grid.Row="1">
            <ikw:SimpleStackPanel Margin="20,10" Spacing="4">
                <!--#region 文本识别-->
                <TextBlock
                    Margin="0,8,0,4"
                    Style="{DynamicResource BodyStrongTextBlockStyle}"
                    Text="{DynamicResource Ocr}" />

                <ui:SettingsCard Description="{DynamicResource Standalone_OcrShowAnnotationDescription}" Header="{DynamicResource Standalone_OcrShowAnnotationHeader}">
                    <ui:SettingsCard.HeaderIcon>
                        <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.ImageSplit_20_Regular}" />
                    </ui:SettingsCard.HeaderIcon>
                    <ui:ToggleSwitch
                        IsOn="{Binding Settings.IsOcrShowingAnnotated}"
                        OffContent="{DynamicResource Disable}"
                        OnContent="{DynamicResource Enable}" />
                </ui:SettingsCard>

                <ui:SettingsCard Description="{DynamicResource Standalone_OcrShowTextControlDescription}" Header="{DynamicResource Standalone_OcrShowTextControlHeader}">
                    <ui:SettingsCard.HeaderIcon>
                        <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.PanelRightContract_20_Regular}" />
                    </ui:SettingsCard.HeaderIcon>
                    <ui:ToggleSwitch
                        IsOn="{Binding Settings.IsOcrShowingTextControl}"
                        OffContent="{DynamicResource Disable}"
                        OnContent="{DynamicResource Enable}" />
                </ui:SettingsCard>
                <!--#endregion-->

                <!--#region 图片翻译-->
                <TextBlock
                    Margin="0,16,0,4"
                    Style="{DynamicResource BodyStrongTextBlockStyle}"
                    Text="{DynamicResource ImageTranslate}" />

                <ui:SettingsCard Description="{DynamicResource Standalone_ImTranWindowModeDescription}" Header="{DynamicResource Standalone_ImTranWindowModeHeader}">
                    <ui:SettingsCard.HeaderIcon>
                        <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.WindowApps_20_Regular}" />
                    </ui:SettingsCard.HeaderIcon>
                    <ComboBox
                        DisplayMemberPath="Display"
                        ItemsSource="{Binding DataProvider.ImageTranslateWindowModes}"
                        SelectedValue="{Binding Settings.ImageTranslateWindowMode}"
                        SelectedValuePath="Value" />
                </ui:SettingsCard>

                <ui:SettingsCard Description="{DynamicResource Standalone_ImTranShowAnnotatedDescription}" Header="{DynamicResource Standalone_ImTranShowAnnotatedHeader}">
                    <ui:SettingsCard.HeaderIcon>
                        <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.ImageSplit_20_Regular}" />
                    </ui:SettingsCard.HeaderIcon>
                    <ui:ToggleSwitch
                        IsOn="{Binding Settings.IsImTranShowingAnnotated}"
                        OffContent="{DynamicResource Disable}"
                        OnContent="{DynamicResource Enable}" />
                </ui:SettingsCard>

                <ui:SettingsCard Description="{DynamicResource Standalone_ImTranShowTextControlDescription}" Header="{DynamicResource Standalone_ImTranShowTextControlHeader}">
                    <ui:SettingsCard.HeaderIcon>
                        <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.PanelRightContract_20_Regular}" />
                    </ui:SettingsCard.HeaderIcon>
                    <ui:ToggleSwitch
                        IsOn="{Binding Settings.IsImTranShowingTextControl}"
                        OffContent="{DynamicResource Disable}"
                        OnContent="{DynamicResource Enable}" />
                </ui:SettingsCard>

                <ui:SettingsCard Description="{DynamicResource Standalone_LayoutAnalysisDescription}" Header="{DynamicResource Standalone_LayoutAnalysisHeader}">
                    <ui:SettingsCard.HeaderIcon>
                        <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.TableOffsetSettings_20_Regular}" />
                    </ui:SettingsCard.HeaderIcon>
                    <ComboBox
                        DisplayMemberPath="Display"
                        ItemsSource="{Binding DataProvider.LayoutAnalysisModes}"
                        SelectedValue="{Binding Settings.LayoutAnalysisMode}"
                        SelectedValuePath="Value" />
                </ui:SettingsCard>

                <ui:SettingsExpander Header="{DynamicResource Standalone_ImTranLanguageDetector}">
                    <ui:SettingsExpander.HeaderIcon>
                        <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.SlideSearch_20_Regular}" />
                    </ui:SettingsExpander.HeaderIcon>
                    <ComboBox
                        DisplayMemberPath="Display"
                        ItemsSource="{Binding DataProvider.LanguageDetectors}"
                        SelectedValue="{Binding Settings.ImageTranslateLanguageDetector}"
                        SelectedValuePath="Value" />

                    <ui:SettingsExpander.Items>
                        <ui:SettingsCard
                            Description="{DynamicResource Standalone_ImTranLocalDetectorDescription}"
                            Header="{DynamicResource Standalone_ImTranLocalDetector}"
                            Visibility="{Binding Settings.ImageTranslateLanguageDetector, Converter={cnvt:LanguageDetectorTypeVisibilityConverter}, ConverterParameter=Local}">
                            <ikw:SimpleStackPanel Orientation="Horizontal" Spacing="12">
                                <Slider
                                    x:Name="PART_ImTranDetectorRate"
                                    IsSnapToTickEnabled="True"
                                    Maximum="0.99"
                                    Minimum="0.01"
                                    TickFrequency="0.01"
                                    Value="{Binding Settings.ImageTranslateLocalDetectorRate}" />
                                <TextBlock VerticalAlignment="Center" Text="{Binding ElementName=PART_ImTranDetectorRate, Path=Value, StringFormat={}{0:0.00}}" />
                            </ikw:SimpleStackPanel>
                        </ui:SettingsCard>

                        <ui:SettingsCard Description="{DynamicResource Standalone_ImTranDefaultSourceLanguageDescription}" Header="{DynamicResource Standalone_ImTranDefaultSourceLanguage}">
                            <ComboBox
                                DisplayMemberPath="Display"
                                ItemsSource="{Binding DataProvider.LangEnums}"
                                SelectedValue="{Binding Settings.ImageTranslateSourceLangIfAuto}"
                                SelectedValuePath="Value" />
                        </ui:SettingsCard>

                        <ui:SettingsCard Description="{DynamicResource Standalone_ImTranFirstLanguageDescription}" Header="{DynamicResource Standalone_ImTranFirstLanguage}">
                            <ComboBox
                                DisplayMemberPath="Display"
                                ItemsSource="{Binding DataProvider.LangEnums}"
                                SelectedValue="{Binding Settings.ImageTranslateFirstLanguage}"
                                SelectedValuePath="Value" />
                        </ui:SettingsCard>

                        <ui:SettingsCard Description="{DynamicResource Standalone_ImTranSecondLanguageDescription}" Header="{DynamicResource Standalone_ImTranSecondLanguage}">
                            <ComboBox
                                DisplayMemberPath="Display"
                                ItemsSource="{Binding DataProvider.LangEnums}"
                                SelectedValue="{Binding Settings.ImageTranslateSecondLanguage}"
                                SelectedValuePath="Value" />
                        </ui:SettingsCard>
                    </ui:SettingsExpander.Items>
                </ui:SettingsExpander>
                <!--#endregion-->
            </ikw:SimpleStackPanel>
        </ui:ScrollViewerEx>
    </Grid>
</ui:Page>
